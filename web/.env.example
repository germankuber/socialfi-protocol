# Copy this file to `web/.env.local` and adjust the endpoints.

# ── SocialFi parachain ─────────────────────────────────────────────────
#
# `VITE_WS_URL` is the production default used by the UI. `VITE_LOCAL_WS_URL`
# is the one picked up when the scripted dev flow runs — it can point at a
# different port when `STACK_PORT_OFFSET` is set.

VITE_LOCAL_WS_URL=ws://127.0.0.1:9944
VITE_WS_URL=ws://127.0.0.1:9944

# ── Polkadot People parachain ──────────────────────────────────────────
#
# Identity (display name + judgement) lives on the People system
# parachain. The UI opens a second PAPI connection here to read identity
# state and to submit `set_identity` / `request_judgement` from the
# user's wallet.
#
# Production: the public Polkadot People RPC.
# Local dev: point this at your People fork (e.g. zombienet + chopsticks).

VITE_PEOPLE_WS_URL=wss://polkadot-people-rpc.polkadot.io
